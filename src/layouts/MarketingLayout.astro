---
import '../styles/global.css';
import '../styles/marketing.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Verfix — Browser verification for AI-generated web apps',
  description = 'Verfix gives AI coding agents a local browser verification runtime. Run deterministic flows, assert UI state, get structured JSON with fix_hint.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="verfix, ai coding agents, browser verification runtime, loop engineering, agent verifier, agentic coding loop, claude code testing, cursor browser testing, codex verification, AGENTS.md, web app testing, structured testing feedback, playwright for ai agents" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={`https://verfix.dev${Astro.url.pathname}`} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Verfix" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://verfix.dev/verfixCard.png" />
  <meta property="og:url" content={`https://verfix.dev${Astro.url.pathname}`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://verfix.dev/verfixCard.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
  />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="Verfix Blog" href="/rss.xml" />
  <!-- Machine-readable reference for AI agents/assistants — see https://llmstxt.org -->
  <link rel="llms.txt" href="/llms.txt" />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Verfix',
    alternateName: 'verfix',
    description: 'Local-first browser verification runtime for AI coding agents — the verifier in the agent loop. Agents write the flow, run it, and get structured JSON failure reports with fix hints. No Docker required.',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'macOS, Linux, Windows',
    softwareVersion: '0.4.0',
    url: 'https://verfix.dev',
    downloadUrl: 'https://www.npmjs.com/package/verfix',
    installUrl: 'https://www.npmjs.com/package/verfix',
    codeRepository: 'https://github.com/verfix-dev/verfix',
    license: 'https://github.com/verfix-dev/verfix/blob/main/LICENSE.md',
    softwareRequirements: 'Node.js 20+',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    author: {
      '@type': 'Organization',
      name: 'Verfix',
      url: 'https://github.com/verfix-dev',
    },
  })} />
</head>
<body>
  <nav class="site-nav" aria-label="Main navigation">
    <a href="/" class="nav-logo" aria-label="Verfix home">
      <img src="/logo.png" alt="Verfix Logo" width="20" height="20" class="logo-img" />
      Verfix
    </a>
    <ul class="nav-links" role="list">
      <li><a href="/docs">Docs</a></li>
      <li><a href="/cli-reference">CLI</a></li>
      <li><a href="/agent-integration">Agents</a></li>
      <li><a href="/blog">Blog</a></li>
      <li>
        <a href="https://github.com/verfix-dev/verfix" target="_blank" rel="noopener noreferrer">
          GitHub
        </a>
      </li>
      <li><a href="/getting-started" class="nav-cta">Get Started →</a></li>
    </ul>
  </nav>

  <slot />

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <div class="footer-wordmark">
          <img src="/logo.png" alt="Verfix Logo" width="18" height="18" class="logo-img" />
          Verfix
        </div>
        <p class="footer-tagline">Browser verification for AI-generated apps</p>
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="https://github.com/verfix-dev/verfix" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.npmjs.com/package/verfix" target="_blank" rel="noopener noreferrer">npm</a>
        <a href="/docs">Docs</a>
        <a href="/blog">Blog</a>
        <a href="/rss.xml" target="_blank" rel="noopener noreferrer">RSS</a>
        <a href="/llms.txt" target="_blank" rel="noopener noreferrer">llms.txt</a>
        <a href="/telemetry">Telemetry</a>
        <a href="https://github.com/verfix-dev/verfix/blob/main/LICENSE.md" target="_blank" rel="noopener noreferrer">Apache 2.0</a>
      </nav>
    </div>
    <div class="footer-bottom">
      <span>verfix</span>
      <span class="footer-version">v0.4.0</span>
    </div>
  </footer>
</body>
</html>