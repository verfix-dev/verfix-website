---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import TerminalDemo from '../components/TerminalDemo.astro';
import CopyButton from '../components/CopyButton.astro';

const agentPrompt = `Set up Verfix in this project to verify UI changes after you make them.

1. Run: npx verfix init --yes (strict mode, no AI key needed)
2. Read AGENTS.md and .verfix/INSTRUCTIONS.md for the full workflow
3. From now on, after any UI change: write or update the relevant flow in
   verfix.config.json using the real selector from the component you just
   edited, run "verfix run --flow <id> --output json", and fix the failure
   (in the flow/config first — only touch app source for a genuine bug)
   before calling the task done.`;

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is Verfix an AI agent?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. Verfix is the execution infrastructure for AI agents — the observability, retry mechanics, and structured output that let an agent verify its own UI changes.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need Docker, an account, or AI to use Verfix?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "No to all three. Strict mode (the default) runs entirely in-process on Node.js 20+, needs no AI key, and there's no hosted SaaS to sign up for. Docker is only needed for the opt-in --server runtime, used by the future hosted CI product.",
      },
    },
    {
      '@type': 'Question',
      name: 'Will an agent rewrite my app to make a broken test pass?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "That's the failure mode Verfix is built to prevent. Agents are steered to fix the flow, not the app source, and a git-baseline source guard can block a run that edits project code to satisfy a selector.",
      },
    },
    {
      '@type': 'Question',
      name: 'What is loop engineering?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Designing the goal, verifier, state, stop condition, and escalation of an agent's iteration loop, instead of prompting turn by turn. Verfix is the verifier half — typed pass/fail, JSON state between iterations, exit codes as the stop condition, and a hand-off to a human when it's stuck.",
      },
    },
    {
      '@type': 'Question',
      name: 'What does Verfix cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Nothing. Verfix is free and open source under the Apache 2.0 license.',
      },
    },
  ],
};
---

<MarketingLayout>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <main>

    <!-- ── HERO ─────────────────────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-left">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
v0.4.0 — now on npm
        </div>

        <h1 class="hero-headline">
          Your coding agent says<br />
          <span class="hero-accent">"fixed."</span> Verfix checks.
        </h1>

        <p class="hero-sub">
          Verfix closes the loop: deterministic browser verification for AI coding
          agents.<br class="hero-sub-break" />
          Local-first, no Docker — structured JSON for agents, a recorded trace for humans.
        </p>

        <div class="hero-actions">
          <div class="install-box">
            <code class="install-cmd">npx verfix init</code>
            <CopyButton text="npx verfix init" label="Copy" />
          </div>

          <div class="hero-links">
            <a
              href="https://github.com/verfix-dev/verfix"
              class="hero-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              View on GitHub →
            </a>
            <span class="hero-links-divider" aria-hidden="true">·</span>
            <CopyButton
              text={agentPrompt}
              label="Copy setup prompt for your agent"
              variant="text"
              class="hero-link"
            />
          </div>
        </div>
      </div>

      <div class="hero-right">
        <TerminalDemo />
      </div>
    </section>

    <!-- ── BENCHMARK ────────────────────────────────────────────────── -->
    <section class="page-section">
      <p class="section-label">Loop closure</p>
      <h2 class="section-title">Does it actually close the loop? We measure it.</h2>
      <p class="section-sub">
        The <a href="https://github.com/verfix-dev/verfix/tree/main/benchmark" target="_blank" rel="noopener noreferrer">loop-closure benchmark</a>:
        8 deliberately broken tiny apps spanning a failure taxonomy — drifted selectors, an
        occluding modal, a stale session, changed copy, a broken API, and more. The agent gets
        <strong> only Verfix's JSON</strong> as its failure signal — no human hints.
      </p>

      <div class="bm-table">
        <div class="bm-row bm-row-head">
          <span>Agent</span><span>Closure rate</span><span>Mean iterations</span>
        </div>
        <div class="bm-row">
          <span>Real coding agent</span>
          <span class="bm-highlight">6/8 (75%)</span>
          <span>2</span>
        </div>
        <div class="bm-row">
          <span class="row-dim">Null agent (does nothing)</span>
          <span class="row-dim">0/8 — enforced in CI</span>
          <span class="row-dim">—</span>
        </div>
        <div class="bm-row">
          <span class="row-dim">Oracle (known-good fix)</span>
          <span class="row-dim">8/8 — enforced in CI</span>
          <span class="row-dim">2</span>
        </div>
      </div>

      <p class="section-sub" style="margin-top: 1.75rem; margin-bottom: 0; max-width: 680px;">
        Anti-cheat invariants mean deleting an assertion doesn't count as closing the loop —
        both failed cases were the agent getting caught fixing things the wrong way. The
        benchmark self-tests in CI: a null agent that scores anything but 0% or an oracle that
        scores anything but 100% fails the build. Results are from v0.4.0, 2026-07-11 —
        <a href="https://github.com/verfix-dev/verfix/tree/main/benchmark" target="_blank" rel="noopener noreferrer">run it with your own agent</a>.
      </p>
    </section>

    <!-- ── PROBLEM / SOLUTION ────────────────────────────────────────── -->
    <section class="page-section" style="padding-top: 0;">
      <p class="section-label">The problem</p>
      <h2 class="section-title">Stop manually clicking through flows</h2>
      <p class="section-sub">
        AI agents generate entire application flows in seconds. Verifying those flows
        still requires a human.
      </p>

      <div class="compare-grid">
        <div class="compare-col">
          <div class="compare-header">
            <span class="badge badge-bad">WITHOUT VERFIX</span>
          </div>
          <div class="compare-row"><span class="row-num">1</span><span>Agent writes UI code</span></div>
          <div class="compare-row"><span class="row-num">2</span><span class="row-bad">You open browser manually</span></div>
          <div class="compare-row"><span class="row-num">3</span><span class="row-bad">Click through every flow</span></div>
          <div class="compare-row"><span class="row-num">4</span><span class="row-bad">Spot the bug yourself</span></div>
          <div class="compare-row"><span class="row-num">5</span><span class="row-bad">Tell the agent what broke</span></div>
        </div>
        <div class="compare-col">
          <div class="compare-header">
            <span class="badge badge-good">WITH VERFIX</span>
          </div>
          <div class="compare-row"><span class="row-num">1</span><span>Agent writes UI code</span></div>
          <div class="compare-row"><span class="row-num">2</span><span class="row-cmd">verfix run --flow login</span></div>
          <div class="compare-row"><span class="row-num">3</span><span class="row-good">Structured JSON + fix_hint returned</span></div>
          <div class="compare-row"><span class="row-num">4</span><span class="row-good">Agent reads hint, fixes, retries</span></div>
          <div class="compare-row"><span class="row-num">5</span><span class="row-dim">You review timeline if needed</span></div>
        </div>
      </div>
    </section>

    <!-- ── HOW IT WORKS ──────────────────────────────────────────────── -->
    <section class="page-section" style="padding-top: 0;">
      <p class="section-label">How it works</p>
      <h2 class="section-title">Three steps from zero to verified</h2>
      <p class="section-sub">
        This is <a href="/agent-integration/">loop engineering</a>: a goal, a verifier, and a stop
        condition — not another model grading its own work. Verfix is the verifier.
      </p>

      <div class="steps-grid">
        <div class="step-card">
          <p class="step-index">STEP 01</p>
          <p class="step-cmd">verfix init</p>
          <h3 class="step-title">Configure in 30 seconds</h3>
          <p class="step-desc">
            The wizard detects your app's URL, makes sure Chromium is available (no Docker,
            just Node.js), and generates <code class="inline-code">AGENTS.md</code> — read
            natively by Claude Code, Cursor, Codex, and Copilot — plus an empty
            <code class="inline-code">verfix.config.json</code>. No preset flows — the agent
            writes the first one from your actual source.
          </p>
        </div>
        <div class="step-card">
          <p class="step-index">STEP 02</p>
          <p class="step-cmd">verfix run --flow &lt;id&gt;</p>
          <h3 class="step-title">Agent-driven verify loop</h3>
          <p class="step-desc">
            Every UI change triggers a flow run — in-process, in your terminal, no queue to
            poll. The agent receives <code class="inline-code">passed</code>,
            <code class="inline-code">failures[]</code>, and <code class="inline-code">fix_hint</code>.
            It fixes and retries autonomously, and a source guard flags it if it tries to
            rewrite your app code instead of the flow.
          </p>
        </div>
        <div class="step-card">
          <p class="step-index">STEP 03</p>
          <p class="step-cmd">verfix show &lt;id&gt;</p>
          <h3 class="step-title">Recorded trace, on demand</h3>
          <p class="step-desc">
            If the agent can't self-fix, <code class="inline-code">verfix show</code> opens the
            full Playwright trace for that run — every action, navigation, console error,
            network request, and failure screenshot, replayed exactly.
          </p>
        </div>
      </div>
    </section>

    <!-- ── WHY NOT RAW PLAYWRIGHT ──────────────────────────────────────── -->
    <section class="page-section" style="padding-top: 0;">
      <p class="section-label">The alternative</p>
      <h2 class="section-title">Why not just let the agent drive a browser?</h2>
      <p class="section-sub">
        You can — but an improvised check is the agent grading its own homework with a rubric
        it rewrites every iteration. Verfix inverts it: a fixed instrument the agent can push
        against.
      </p>

      <div class="wnp-table">
        <div class="wnp-row wnp-row-head">
          <span></span><span>Agent drives a browser</span><span>Verfix</span>
        </div>
        <div class="wnp-row">
          <span class="wnp-dim">Check between iterations</span>
          <span class="row-bad">different every time</span>
          <span class="row-good">byte-identical</span>
        </div>
        <div class="wnp-row">
          <span class="wnp-dim">Failure output</span>
          <span class="row-bad">prose / screenshots to interpret</span>
          <span class="row-good">8 typed failure codes + fix_hint</span>
        </div>
        <div class="wnp-row">
          <span class="wnp-dim">Cost per verification</span>
          <span class="row-bad">LLM tokens, every time</span>
          <span class="row-good">zero tokens in strict mode</span>
        </div>
        <div class="wnp-row">
          <span class="wnp-dim">Agent edits the measuring stick</span>
          <span class="row-bad">silent</span>
          <span class="row-good">flagged (source-guard)</span>
        </div>
        <div class="wnp-row">
          <span class="wnp-dim">Evidence</span>
          <span class="row-bad">whatever it mentions</span>
          <span class="row-good">recorded Playwright trace, replay with verfix show</span>
        </div>
      </div>
    </section>

    <!-- ── SCREENSHOTS ──────────────────────────────────────────────────
         Placeholder for product screenshots (e.g. the Playwright trace
         viewer via `verfix show`, a terminal recording of the fix loop,
         or the verfix.config.json flow library in an editor).
         Uncomment and fill in with real assets, then remove this comment.

    <section class="page-section" style="padding-top: 0;">
      <p class="section-label">See it in action</p>
      <h2 class="section-title">The trace, not a video</h2>
      <p class="section-sub">
        Every run records a full Playwright trace — every action, console log, network
        request, and failure screenshot, replayed exactly.
      </p>

      <div class="screenshot-frame">
        <img src="/screenshots/verfix-show-trace.png" alt="verfix show opening a Playwright trace viewer with a failed selector highlighted" loading="lazy" />
      </div>
    </section>

    ────────────────────────────────────────────────────────────────── -->

    <!-- ── VERIFICATION MODES ───────────────────────────────────────── -->
    <section class="page-section" style="padding-top: 0;">
      <p class="section-label">Verification modes</p>
      <h2 class="section-title">Deterministic by default, AI when it earns it</h2>
      <p class="section-sub">
        Each flow can override the global mode — stable flows stay strict, evolving ones use
        assisted.
      </p>

      <div class="verify-table">
        <div class="verify-row verify-row-head">
          <span>Mode</span><span>Selector strategy</span><span>AI</span><span>Best for</span>
        </div>
        <div class="verify-row">
          <span class="mode-tag tag-strict">strict</span>
          <span>CSS / <code class="inline-code">data-testid</code> only, fails explicitly</span>
          <span class="row-dim">none</span>
          <span>CI/CD, regression</span>
        </div>
        <div class="verify-row">
          <span class="mode-tag tag-assisted">assisted</span>
          <span>Selector → semantic → AI fallback, in that order</span>
          <span>on failure</span>
          <span>Active development</span>
        </div>
        <div class="verify-row">
          <span class="mode-tag tag-exploratory">exploratory</span>
          <span>Natural-language task, AI plans and drives</span>
          <span>core driver</span>
          <span>Ad-hoc QA, discovery</span>
        </div>
      </div>

      <p class="section-sub" style="margin-top: 1.75rem; margin-bottom: 0; max-width: 640px;">
        Whichever mode fails, the fix goes into the flow, not your app — the easy failure mode for
        an agent under pressure is sprinkling <code class="inline-code">data-testid</code> through
        your components until a test goes green. A git-baseline <strong>source guard</strong> reports
        every project file an agent touches mid-fix, and <code class="inline-code">sourceCodePolicy:
        "block"</code> can fail the run until a bogus edit is reverted. See
        <a href="/config-first-verification/">Config-First Verification</a>.
      </p>
    </section>

    <!-- ── QUICKSTART ────────────────────────────────────────────────── -->
    <section class="page-section" style="padding-top: 0;">
      <p class="section-label">Quickstart</p>
      <h2 class="section-title">Up in four commands</h2>
      <p class="section-sub">Requirements: Node.js 20+. That's it — no Docker, no accounts, no cloud.</p>

      <div>
        <div class="qs-step">
          <div class="qs-num">1</div>
          <div>
            <p class="qs-label">Install</p>
            <div class="qs-code-wrap">
              <code class="qs-code">npm install -g verfix</code>
              <CopyButton text="npm install -g verfix" variant="icon" class="qs-copy-btn" />
            </div>
          </div>
        </div>

        <div class="qs-step">
          <div class="qs-num">2</div>
          <div>
            <p class="qs-label">Init your project</p>
            <div class="qs-code-wrap">
              <code class="qs-code">npx verfix init</code>
              <CopyButton text="npx verfix init" variant="icon" class="qs-copy-btn" />
            </div>
            <p class="qs-note">
              The wizard detects your app URL, creates verfix.config.json, and writes AGENTS.md.
              Default mode is <code class="inline-code">strict</code> — fully deterministic,
              no AI key needed. Use <code class="inline-code">verfix init --yes</code> for
              non-interactive mode.
            </p>
          </div>
        </div>

        <div class="qs-step">
          <div class="qs-num">3</div>
          <div>
            <p class="qs-label">Run a flow</p>
            <div class="qs-code-wrap">
              <code class="qs-code">verfix run --flow login --output json</code>
              <CopyButton text="verfix run --flow login --output json" variant="icon" class="qs-copy-btn" />
            </div>
            <p class="qs-note">Runs in-process. Returns structured JSON. Exit code 0 on pass, 1 on failure.</p>
          </div>
        </div>

        <div class="qs-step">
          <div class="qs-num">4</div>
          <div>
            <p class="qs-label">Inspect the trace</p>
            <div class="qs-code-wrap">
              <code class="qs-code">verfix show</code>
              <CopyButton text="verfix show" variant="icon" class="qs-copy-btn" />
            </div>
            <p class="qs-note">
              Opens the newest run's full Playwright trace — every action, console log, network
              request, and screenshot. Runs and traces persist under
              <code class="inline-code">.verfix/runs/</code>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── FAQ ────────────────────────────────────────────────────────── -->
    <section class="page-section" style="padding-top: 0;">
      <p class="section-label">FAQ</p>
      <h2 class="section-title">Questions, answered</h2>

      <div class="faq-list">
        <details class="faq-item">
          <summary class="faq-q">Is Verfix an AI agent?</summary>
          <p class="faq-a">
            No. Verfix is the <em>execution infrastructure</em> for AI agents — the observability,
            retry mechanics, and structured output that let an agent verify its own UI changes.
          </p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">Do I need Docker, an account, or AI to use it?</summary>
          <p class="faq-a">
            No to all three. <code class="inline-code">strict</code> mode (the default) runs
            entirely in-process on Node.js 20+, needs no AI key, and there's no hosted SaaS to
            sign up for. Docker is only needed for the opt-in <code class="inline-code">--server</code>
            runtime, used by the future hosted CI product.
          </p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">Will an agent rewrite my app to make a broken test pass?</summary>
          <p class="faq-a">
            That's the failure mode Verfix is built to prevent. See
            <a href="/config-first-verification/">Config-First Verification</a> — agents are
            steered to fix the flow, not your source, and a git-baseline source guard can block a
            run that edits project code to satisfy a selector.
          </p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">What is loop engineering?</summary>
          <p class="faq-a">
            Designing the goal, verifier, state, stop condition, and escalation of an agent's
            iteration loop, instead of prompting turn by turn. Verfix is the verifier half —
            typed pass/fail, JSON state between iterations, exit codes as the stop condition, and
            a hand-off to a human when it's stuck.
          </p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">What does it cost?</summary>
          <p class="faq-a">
            Nothing. Verfix is free and open source under the Apache 2.0 license.
          </p>
        </details>
      </div>
    </section>

  </main>

  <!-- ── CLOSING CTA ──────────────────────────────────────────────────── -->
  <section class="cta-band">
    <div class="cta-inner">
      <h2 class="cta-title">Verify your first flow in under 2 minutes</h2>
      <p class="cta-sub">No Docker, no accounts, no cloud. Just Node.js and one command.</p>
      <div class="cta-actions">
        <div class="install-box cta-install-box">
          <code class="install-cmd">npx verfix init</code>
          <CopyButton text="npx verfix init" label="Copy" />
        </div>
        <a href="/getting-started/" class="cta-link">Read the docs →</a>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  /* ── Benchmark table ─────────────────────────────────────────────── */
  .bm-table {
    border: 1px solid var(--vf-border);
    border-radius: 12px;
    overflow: hidden;
  }
  .bm-row {
    display: grid;
    grid-template-columns: 1fr 10rem 10rem;
    gap: 1.25rem;
    align-items: center;
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--vf-border-subtle);
    font-size: 0.8125rem;
    color: var(--vf-text-secondary);
  }
  .bm-row:last-child { border-bottom: none; }
  .bm-row-head {
    background: var(--vf-surface-2);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--vf-text-tertiary);
  }
  .bm-highlight {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    color: var(--vf-green);
  }

  /* ── "Why not raw Playwright" table ──────────────────────────────── */
  .wnp-table {
    border: 1px solid var(--vf-border);
    border-radius: 12px;
    overflow: hidden;
  }
  .wnp-row {
    display: grid;
    grid-template-columns: 13rem 1fr 1fr;
    gap: 1.25rem;
    align-items: center;
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--vf-border-subtle);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78125rem;
  }
  .wnp-row:last-child { border-bottom: none; }
  .wnp-row-head {
    background: var(--vf-surface-2);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--vf-text-tertiary);
  }
  .wnp-dim {
    color: var(--vf-text);
    font-family: 'Geist', sans-serif;
    font-weight: 600;
    font-size: 0.8125rem;
  }

  @media (max-width: 768px) {
    .bm-row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
      align-items: start;
    }
    .bm-row-head { display: none; }
    .wnp-row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
      align-items: start;
    }
    .wnp-row-head { display: none; }
  }
</style>